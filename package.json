{
  "name": "semantic-scholar-mcp",
  "version": "1.0.0",
  "description": "MCP server for Semantic Scholar API - search papers, authors, citations, and get recommendations from the Semantic Scholar Academic Graph",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "semantic-scholar-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "semantic-scholar",
    "academic",
    "papers",
    "research",
    "citations",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
